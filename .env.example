# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=jobfinder
POSTGRES_PASSWORD=jobfinder
POSTGRES_DB=jobfinder
DATABASE_URL=postgresql://jobfinder:jobfinder@localhost:5432/jobfinder

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail" and paste it below
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Rate Limiting ─────────────────────────────────────────────────────────────
EMAIL_DELAY_MIN=30
EMAIL_DELAY_MAX=60

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
UPLOAD_DIR=/tmp/jobfinder_uploads
