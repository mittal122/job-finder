# ── Database (required) ────────────────────────────────────────────────────────
# The app can't look up its own database connection string from inside the
# database it hasn't connected to yet — this is the one thing that genuinely
# has to be set before the app starts. The defaults below work as-is with
# `docker compose up`; only change them if you're running your own Postgres.
POSTGRES_USER=jobfinder
POSTGRES_PASSWORD=jobfinder
POSTGRES_DB=jobfinder
DATABASE_URL=postgresql://jobfinder:jobfinder@localhost:5432/jobfinder

# ── Secrets encryption (required) ───────────────────────────────────────────────
# Encrypts Gmail App Passwords and AI API keys at rest. Cannot be
# auto-generated and stored in the database it protects — a DB dump would
# then contain both the ciphertext and the key. Generate one with:
#   openssl rand -hex 32
ENCRYPTION_KEY=

# ── Server (optional) ───────────────────────────────────────────────────────────
# PORT=8000

# ── Everything per-account is configured from inside the app ───────────────────
# Sign up, then go to Settings to set (each account configures their own):
#   - Gmail address + App Password — required before that account can send
#     anything. The Settings page links you straight to where to generate
#     an App Password and lets you send a test email before saving.
#   - NVIDIA API key — optional, only used for AI company-name substitution
#     in Bulk Send/Template Map
#   - Campaign send-delay range — optional, sensible defaults already work
# None of this can be pre-seeded via .env — these are per-account settings,
# not app-wide ones, so there's no single value to seed before any accounts
# exist.

# ── Google sign-in (optional) ───────────────────────────────────────────────────
# Lets users sign in with Google instead of (or in addition to) email and
# password. Email+password works completely standalone without these —
# the "Sign in with Google" button simply doesn't appear if unset. Requires
# registering an OAuth app in Google Cloud Console (unavoidable — Google
# requires this); set the callback URL there to:
#   <PUBLIC_BASE_URL>/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Advanced (optional) ─────────────────────────────────────────────────────────
# Where uploaded resumes are temporarily stored. Defaults to your OS's temp
# directory — only set this if you need a specific location (e.g. a mounted
# volume).
# UPLOAD_DIR=/tmp/jobfinder_uploads

# Used to build the unsubscribe link in outgoing email and the Google OAuth
# callback URL. Defaults to localhost, which is fine for local/Docker use —
# set this to your real domain if deploying anywhere reachable from outside
# your own machine, otherwise recipients' unsubscribe links won't work.
# PUBLIC_BASE_URL=https://your-domain.com
